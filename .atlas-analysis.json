  "keyFeatures": [
    "Real-time SoloQ and Flex rank tracking",
    "Daily LP gain/loss highlights",
    "Riot API rate limiting and caching",
    "Friend list management with custom emotes",
    "Champion mastery and role detection",
    "Persistent cache with automatic sync",
    "Responsive masonry grid layout",
    "API statistics and monitoring"
  ],
  "publicApiSurface": [
    "GET /api/ladder - Fetch ranked ladder with all tracked players",
    "GET /api/player?gameName=X&tagLine=Y - Get individual player stats",
    "GET /api/friends - List all tracked friends",
    "POST /api/friends - Add new friend to tracker",
    "DELETE /api/friends/:gameName/:tagLine - Remove friend",
    "GET /api/status - Server status and rate limit info",
    "POST /api/force-refresh - Force immediate ladder refresh"
  ]
